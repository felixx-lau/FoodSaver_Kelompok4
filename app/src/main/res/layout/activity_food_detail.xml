<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Fixed Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:elevation="2dp">

        <TextView
            android:id="@+id/tvBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← "
            android:textSize="20sp"
            android:textColor="#1A1A1A"
            android:padding="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Detail Makanan"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Foto -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="220dp">

                <ImageView
                    android:id="@+id/imgFood"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="#E8F5E9"
                    android:src="@android:drawable/ic_menu_gallery"/>

                <TextView
                    android:id="@+id/tvDiscountBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hemat 0%"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="#4CAF50"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="16dp"/>
            </FrameLayout>

            <!-- Info Utama -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvFoodName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nama Makanan"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvPartnerInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nama Toko · sisa 5 porsi"
                    android:textSize="13sp"
                    android:textColor="#888888"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvDiscountPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp0"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#2E7D32"/>

                    <TextView
                        android:id="@+id/tvOriginalPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp0"
                        android:textSize="14sp"
                        android:textColor="#AAAAAA"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Deskripsi -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Deskripsi"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:textSize="14sp"
                    android:textColor="#555555"/>
            </LinearLayout>

            <!-- Lokasi -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 Alamat Penjual"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Alamat..."
                    android:textSize="14sp"
                    android:textColor="#555555"/>
            </LinearLayout>

            <!-- Opsi Ambil -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Metode Pengambilan"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/btnPickup"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#E8F5E9"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🚶" android:textSize="18sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pickup" android:textSize="12sp" android:textColor="#2E7D32" android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnDelivery"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#F5F5F5"
                        android:layout_marginStart="6dp"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🚴" android:textSize="18sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Delivery" android:textSize="12sp" android:textColor="#555555"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Slot Waktu -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pilih Slot Waktu"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView android:id="@+id/slot1" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="17:00 - 17:30" android:textSize="12sp" android:gravity="center" android:background="#F5F5F5" android:layout_marginEnd="4dp" android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/slot2" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="17:30 - 18:00" android:textSize="12sp" android:gravity="center" android:background="#F5F5F5" android:layout_marginStart="4dp" android:clickable="true" android:focusable="true"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:id="@+id/slot3" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="18:00 - 18:30" android:textSize="12sp" android:gravity="center" android:background="#F5F5F5" android:layout_marginEnd="4dp" android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/slot4" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="18:30 - 19:00" android:textSize="12sp" android:gravity="center" android:background="#F5F5F5" android:layout_marginStart="4dp" android:clickable="true" android:focusable="true"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Action Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:elevation="8dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginEnd="16dp">

            <TextView
                android:id="@+id/btnMinus"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="-"
                android:textSize="20sp"
                android:gravity="center"
                android:background="#F0F0F0"
                android:textColor="#333333"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/tvQuantity"
                android:layout_width="44dp"
                android:layout_height="wrap_content"
                android:text="1"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="#1A1A1A"/>

            <TextView
                android:id="@+id/btnPlus"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="+"
                android:textSize="20sp"
                android:gravity="center"
                android:background="#F0F0F0"
                android:textColor="#333333"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnAddToCart"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Tambah ke Keranjang"
            android:textSize="14sp"
            android:textStyle="bold"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

</LinearLayout>
